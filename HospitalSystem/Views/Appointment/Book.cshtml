@{
    var doctor = ViewBag.Doctor as HospitalSystem.Models.Doctor;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book Appointment</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      background-image: url('/images/cover1.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: rgba(180, 210, 240, 0.55);
      backdrop-filter: blur(2px);
      z-index: 0;
    }

    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 36px;
      background: rgba(10,22,40,0.45);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255,255,255,0.15);
    }

    .logo {
      display: flex; align-items: center; gap: 10px;
      font-weight: 600; font-size: 1.05rem;
      color: white; text-decoration: none;
    }
    .logo-icon {
      width: 30px; height: 30px;
      background: linear-gradient(135deg, #4fc3f7, #2196f3);
      border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-icon svg { width: 17px; height: 17px; fill: white; }

    .nav-actions { display: flex; gap: 10px; }
    .btn-nav {
      display: flex; align-items: center; gap: 7px;
      padding: 8px 18px; border-radius: 7px;
      font-size: 0.85rem; font-weight: 500;
      cursor: pointer; text-decoration: none;
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.1);
      color: white; transition: all 0.2s;
    }
    .btn-nav:hover { background: rgba(255,255,255,0.2); color: white; }
    .btn-nav svg { width: 15px; height: 15px; stroke: currentColor; fill: none; }

    .page-wrapper {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 100px 20px 40px;
    }

    .alert-error {
      width: 100%;
      max-width: 660px;
      background: rgba(255, 220, 210, 0.95);
      border-left: 4px solid #e53935;
      border-radius: 8px;
      padding: 14px 20px;
      margin-bottom: 16px;
      color: #b71c1c;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .form-card {
      background: rgba(255,255,255,0.97);
      border-radius: 16px;
      padding: 40px 44px;
      width: 100%;
      max-width: 660px;
      box-shadow: 0 12px 40px rgba(30,60,120,0.15);
    }

    .form-card h2 {
      font-size: 1.35rem;
      font-weight: 600;
      color: #1a2a4a;
      text-align: center;
      margin-bottom: 28px;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-size: 0.88rem;
      font-weight: 500;
      color: #1a2a4a;
      margin-bottom: 7px;
    }

    .form-group input {
      width: 100%;
      padding: 11px 14px;
      border-radius: 8px;
      border: 1.5px solid #d0d8e8;
      font-size: 0.95rem;
      font-family: 'DM Sans', sans-serif;
      color: #1a2a4a;
      outline: none;
      transition: border 0.2s;
      background: #f8fafd;
    }
    .form-group input:focus { border-color: #2196f3; background: white; }

    .btn-save {
      width: 100%;
      padding: 13px;
      background: #2e7d32;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      margin-top: 8px;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-save:hover { background: #1b5e20; transform: translateY(-1px); }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><path d="M12 4c-4.41 0-8 3.59-8 8s3.59 8 8 8 8-3.59 8-8-3.59-8-8-8zm1 12h-2v-6h2v6zm0-8h-2V6h2v2z"/></svg>
      </div>
      HospitalSystem
    </a>
    <div class="nav-actions">
      <a href="/Appointment/Index" class="btn-nav">
        <svg viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Book Appointment
      </a>
      <a href="/Appointment/AllAppointments" class="btn-nav">
        <svg viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        All Appointments
      </a>
    </div>
  </nav>

  <div class="page-wrapper">

    @if (ViewBag.Error != null)
    {
      <div class="alert-error">@ViewBag.Error</div>
    }

    <div class="form-card">
      <h2>Make Appointment with Doctor @doctor.Name</h2>

      <form method="post" action="/Appointment/Book?doctorId=@doctor.Id">
        <div class="form-group">
          <label>Patient Name</label>
          <input type="text" name="patientName" placeholder="Enter patient name" required />
        </div>
        <div class="form-group">
          <label>Appointment Date</label>
          <input type="date" name="appointmentDate" required />
        </div>
        <div class="form-group">
  <label>Appointment Time</label>
  <select name="appointmentTime" required style="
    width: 100%;
    padding: 11px 14px;
    border-radius: 8px;
    border: 1.5px solid #d0d8e8;
    font-size: 0.95rem;
    font-family: 'DM Sans', sans-serif;
    color: #1a2a4a;
    outline: none;
    background: #f8fafd;
    cursor: pointer;
  ">
    <option value="">-- Select a time --</option>
    <option value="1900-01-01 09:00:00">9:00 AM</option>
    <option value="1900-01-01 09:30:00">9:30 AM</option>
    <option value="1900-01-01 10:00:00">10:00 AM</option>
    <option value="1900-01-01 10:30:00">10:30 AM</option>
    <option value="1900-01-01 11:00:00">11:00 AM</option>
    <option value="1900-01-01 11:30:00">11:30 AM</option>
    <option value="1900-01-01 12:00:00">12:00 PM</option>
    <option value="1900-01-01 12:30:00">12:30 PM</option>
    <option value="1900-01-01 13:00:00">1:00 PM</option>
    <option value="1900-01-01 13:30:00">1:30 PM</option>
    <option value="1900-01-01 14:00:00">2:00 PM</option>
    <option value="1900-01-01 14:30:00">2:30 PM</option>
    <option value="1900-01-01 15:00:00">3:00 PM</option>
    <option value="1900-01-01 15:30:00">3:30 PM</option>
    <option value="1900-01-01 16:00:00">4:00 PM</option>
    <option value="1900-01-01 16:30:00">4:30 PM</option>
    <option value="1900-01-01 17:00:00">5:00 PM</option>
    <option value="1900-01-01 17:30:00">5:30 PM</option>
    <option value="1900-01-01 18:00:00">6:00 PM</option>
  </select>
</div>
        <button type="submit" class="btn-save">Save Appointment</button>
      </form>
    </div>

  </div>

</body>
</html>
