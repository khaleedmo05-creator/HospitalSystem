@model List<HospitalSystem.Models.Appointment>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>All Appointments - HospitalSystem</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      background-image: url('/images/cover1.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      position: relative;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: rgba(180, 210, 240, 0.55);
      backdrop-filter: blur(2px);
      z-index: 0;
    }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 36px;
      background: rgba(10,22,40,0.45);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(255,255,255,0.15);
    }

    .logo {
      display: flex; align-items: center; gap: 10px;
      font-weight: 600; font-size: 1.05rem;
      color: white; text-decoration: none;
    }
    .logo-icon {
      width: 30px; height: 30px;
      background: linear-gradient(135deg, #4fc3f7, #2196f3);
      border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-icon svg { width: 17px; height: 17px; fill: white; }

    .nav-actions { display: flex; gap: 10px; }
    .btn-nav {
      display: flex; align-items: center; gap: 7px;
      padding: 8px 18px; border-radius: 7px;
      font-size: 0.85rem; font-weight: 500;
      cursor: pointer; text-decoration: none;
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.1);
      color: white; transition: all 0.2s;
    }
    .btn-nav:hover { background: rgba(255,255,255,0.2); color: white; }
    .btn-nav svg { width: 15px; height: 15px; stroke: currentColor; fill: none; }

    /* PAGE */
    .page-wrapper {
      position: relative;
      z-index: 1;
      padding: 110px 40px 60px;
      max-width: 1100px;
      margin: 0 auto;
    }

    h1.page-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      font-weight: 700;
      color: #1a2a4a;
      text-align: center;
      margin-bottom: 32px;
      text-shadow: 0 2px 8px rgba(255,255,255,0.6);
    }

    /* TABLE */
    .table-card {
      background: rgba(255,255,255,0.95);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(30,60,120,0.13);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead tr {
      background: rgba(240,246,255,0.95);
      border-bottom: 2px solid #e0eaf8;
    }

    thead th {
      padding: 16px 20px;
      text-align: left;
      font-size: 0.88rem;
      font-weight: 600;
      color: #1a2a4a;
      letter-spacing: 0.02em;
    }

    tbody tr {
      border-bottom: 1px solid #eef2f8;
      transition: background 0.15s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(33,150,243,0.05); }

    tbody td {
      padding: 14px 20px;
      font-size: 0.9rem;
      color: #2c3e6b;
    }

    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
      background: rgba(33,150,243,0.1);
      color: #1565c0;
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #6b7a8d;
      font-size: 1rem;
    }

    @@media (max-width: 768px) {
      .page-wrapper { padding: 100px 16px 40px; }
      thead th, tbody td { padding: 12px 12px; font-size: 0.82rem; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><path d="M12 4c-4.41 0-8 3.59-8 8s3.59 8 8 8 8-3.59 8-8-3.59-8-8-8zm1 12h-2v-6h2v6zm0-8h-2V6h2v2z"/></svg>
      </div>
      HospitalSystem
    </a>
    <div class="nav-actions">
      <a href="/Appointment/Index" class="btn-nav">
        <svg viewBox="0 0 24 24" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Book Appointment
      </a>
      <a href="/Appointment/AllAppointments" class="btn-nav">
        <svg viewBox="0 0 24 24" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        All Appointments
      </a>
    </div>
  </nav>

  <div class="page-wrapper">
    <h1 class="page-title">All Appointments</h1>

    <div class="table-card">
      @if (Model == null || !Model.Any())
      {
        <div class="empty-state">No appointments found.</div>
      }
      else
      {
        <table>
          <thead>
            <tr>
              <th>Patient</th>
              <th>Doctor</th>
              <th>Specialization</th>
              <th>Date</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var item in Model)
            {
              <tr>
                <td>@item.PatientName</td>
                <td>@item.Doctor.Name</td>
                <td><span class="badge">@item.Doctor.Specialization.Name</span></td>
                <td>@item.AppointmentDate.ToString("yyyy-MM-dd")</td>
                <td>@item.AppointmentTime.ToString("HH:mm")</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </div>

</body>
</html>